---
import "../../styles/landing.css";
import "../../styles/homepage/about-cursor.css";
import SiteFooter from "../../components/SiteFooter.astro";

const GHOST_URL = import.meta.env.GHOST_URL;
const GHOST_API_KEY = import.meta.env.GHOST_API_KEY;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const assetVersion = "20260413-2";

const res = await fetch(
  `${GHOST_URL}/ghost/api/content/posts/?key=${GHOST_API_KEY}&include=tags&fields=slug,title,updated_at,custom_excerpt,feature_image,url`,
);
const { posts: allPosts } = await res.json();
const ghostOrigin = allPosts[0]?.url
  ? new URL(allPosts[0].url).origin
  : GHOST_URL;
const rewriteUrl = (url: string | null) => {
  if (!url || !import.meta.env.PROD) return url;
  return url.replace(ghostOrigin, base);
};
const dateFmt = { day: "numeric", month: "long", year: "numeric" } as const;
const caseStudyOrder = ["design-case-study-ikea", "design-case-study-mapillary"];
const cards = allPosts
  .filter((p: any) => p.tags?.some((t: any) => t.name === "#case-study"))
  .sort((a: any, b: any) => {
    const aIndex = caseStudyOrder.indexOf(a.slug);
    const bIndex = caseStudyOrder.indexOf(b.slug);
    return (
      (aIndex === -1 ? Number.POSITIVE_INFINITY : aIndex) -
      (bIndex === -1 ? Number.POSITIVE_INFINITY : bIndex)
    );
  })
  .map((p: any) => {
    const displayTags = (p.tags ?? [])
      .filter((t: any) => !t.name.startsWith("#"))
      .map((t: any) => t.name);
    return {
      slug: p.slug,
      title: p.title,
      custom_excerpt: p.custom_excerpt ?? null,
      feature_image: rewriteUrl(p.feature_image),
      visualKind: p.slug.includes("ikea")
        ? "ikea"
        : p.slug.includes("mapillary")
          ? "mapillary"
          : null,
      displayTags,
      updatedLabel: `Updated ${new Date(p.updated_at).toLocaleDateString("en-GB", dateFmt)}`,
    };
  });
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Design — József Schaffer</title>
    <link rel="icon" href={`${base}/favicon.png?v=${assetVersion}`} />
  </head>
  <body data-about-cursor-root>
    <section class="mini-hero design-hero">
      <div
        class="design-hero__logo-scene"
        data-gitlab-hero-canvas
        data-base={base}
        aria-hidden="true"
      >
      </div>
      <div class="mini-hero__content">
        <h1 data-about-cursor-select>Hi GitLab,<br />I’m József.</h1>
        <p class="mini-hero__intro" data-about-cursor-select>
          I design complex product systems, prototype the hard parts, and code
          when it helps the team move faster.
        </p>
        <p class="mini-hero__intro" data-about-cursor-select>
          For 15+ years, I’ve turned ambiguous problems into usable,
          well-crafted product experiences, most recently at Inter IKEA.
        </p>
        <p class="mini-hero__intro" data-about-cursor-select>
          These case studies show my product work. The rest of the site shows
          the curiosity, craft, and side projects behind it.
        </p>
      </div>
    </section>

    <ul class="projects-grid case-study-grid case-study-cards">
      {
        cards.map((post: any) => (
          <li
            class:list={[
              "project-card",
              post.visualKind && `project-card--${post.visualKind}`,
            ]}
          >
            <a
              class:list={[
                "project-card__link",
                post.visualKind && "project-card__link--effect",
              ]}
              href={`${base}/${post.slug}/`}
              data-about-cursor-active
            >
              <div
                class:list={[
                  "project-card__canvas",
                  post.visualKind && "project-card__canvas--effect",
                  post.visualKind && `project-card__canvas--${post.visualKind}`,
                ]}
                data-ikea-canvas={post.visualKind === "ikea" ? true : undefined}
                data-mapillary-canvas={
                  post.visualKind === "mapillary" ? true : undefined
                }
                data-base={post.visualKind ? base : undefined}
                data-desktop-texture-zoom={
                  post.visualKind === "mapillary" ? "1.82" : undefined
                }
                data-mobile-texture-zoom={
                  post.visualKind === "mapillary" ? "1.24" : undefined
                }
              >
                {!post.visualKind && post.feature_image && (
                  <img
                    class="project-card__img"
                    src={post.feature_image}
                    alt=""
                    loading="lazy"
                  />
                )}
              </div>
              {post.visualKind ? (
                <div class="project-card__effect-title">
                  <h3>{post.title}</h3>
                </div>
              ) : (
                <div class="project-card__content">
                  <h3 class="project-card__title">{post.title}</h3>
                  {post.displayTags.length > 0 && (
                    <div class="project-card__tags">
                      {post.displayTags.map((tag: string) => (
                        <span
                          class="tag-pill"
                          data-tag={tag.toLowerCase().replace(/\s+/g, "-")}
                        >
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                  {post.custom_excerpt && (
                    <p class="project-card__excerpt">{post.custom_excerpt}</p>
                  )}
                  <span class="project-card__date">{post.updatedLabel}</span>
                </div>
              )}
            </a>
          </li>
        ))
      }
    </ul>

    <a
      class="closing-callout"
      href={`${base}/`}
      data-about-cursor-active
    >
      <canvas
        class="closing-callout__starfield"
        data-starfield
        aria-hidden="true"></canvas>
      <span class="closing-callout__link">
        Continue to jozsefschaffer.com →
      </span>
    </a>

    <SiteFooter />
    <div class="about-cursor" data-about-cursor aria-hidden="true"></div>
    <script>
      import { initGitLabHeroScene } from "../../scripts/gitlab-hero-scene.js";
      import { initIkeaCardScene } from "../../scripts/ikea-card-scene.js";
      import { initMapillaryCardScene } from "../../scripts/mapillary-card-scene.js";

      initGitLabHeroScene();
      initIkeaCardScene();
      initMapillaryCardScene();
    </script>
    <script is:inline type="module" define:vars={{ base }}>
      import(`${base}/js/about-cursor.js`).then((m) => m.initAboutCursor());
      import(`${base}/js/closing-starfield.js`).then((m) =>
        m.initClosingStarfield(),
      );
    </script>
  </body>
</html>
