---
import "../../styles/ghost-content.css";

const GHOST_URL = import.meta.env.GHOST_URL;
const GHOST_API_KEY = import.meta.env.GHOST_API_KEY;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const res = await fetch(
  `${GHOST_URL}/ghost/api/content/posts/?key=${GHOST_API_KEY}&include=tags&fields=slug,title,published_at,updated_at&order=updated_at%20desc`,
);
const { posts: allPosts } = await res.json();
const posts = allPosts.filter(
  (p: any) => !p.tags?.some((t: any) => t.name.toLowerCase() === "hidden"),
);
const dateFmt = { day: "numeric", month: "long", year: "numeric" } as const;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Projects — József Schaffer</title>
    <link rel="icon" href={`${base}/favicon.png`} />
    <style is:global>
      body {
        background-color: #fff;
      }
      .projects {
        max-width: 720px;
        margin: 0 auto;
        padding: 8rem 24px;
      }
      .projects h1 {
        font-size: 3.6rem;
        margin: 0 0 2rem;
      }
      .projects ul {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .projects li + li {
        margin-top: 1.2rem;
      }
      .projects-intro {
        font-size: 1.7rem;
        color: rgba(0, 0, 0, 0.55);
        margin: 0 0 3rem;
        line-height: 1.5;
      }
      .projects a {
        font-size: 1.8rem;
        color: #2a1f23;
        text-decoration: none;
        border-bottom: 1px solid rgba(0, 0, 0, 0.15);
        padding-bottom: 0.1em;
        transition: border-color 0.15s;
      }
      .projects a:hover {
        border-color: #5c2a3e;
      }
      .projects .date {
        font-size: 1.4rem;
        color: rgba(0, 0, 0, 0.4);
        margin-left: 0.75em;
      }
      .back-nav {
        position: fixed;
        top: 24px;
        left: 24px;
        z-index: 100;
        display: inline-flex;
        align-items: center;
        gap: 0.5em;
        padding: 0.6em 1.1em;
        background: rgba(92, 42, 62, 0.12);
        backdrop-filter: blur(12px) saturate(1.4);
        -webkit-backdrop-filter: blur(12px) saturate(1.4);
        border: 2px solid rgba(42, 31, 35, 0.8);
        border-radius: 999px;
        color: #2a1f23;
        font-family:
          "Bricolage Grotesque",
          system-ui,
          -apple-system,
          sans-serif;
        font-size: 2.1rem;
        font-weight: 500;
        text-decoration: none;
        transition:
          background 0.2s ease,
          color 0.2s ease,
          border-color 0.2s ease;
      }
      .back-nav:hover {
        background: #5c2a3e;
        color: #fcf4ee;
        border-color: #5c2a3e;
      }
      .back-nav-arrow {
        font-size: 1.1em;
        line-height: 1;
      }
      @media (max-width: 600px) {
        .back-nav {
          font-size: 1.47rem;
          top: 16px;
          left: 16px;
        }
      }
    </style>
  </head>
  <body>
    <a class="back-nav" href={`${base}/`}>
      <span class="back-nav-arrow">←</span>
      <span>jozsefschaffer.com</span>
    </a>
    <div class="projects">
      <h1>Projects & Posts</h1>
      <p class="projects-intro">
        A mix of side projects, hobby builds, and tech interests I'm tinkering
        with. I hope you find some of these useful.
      </p>
      <ul>
        {
          posts.map((post: any) => {
            const updated = new Date(post.updated_at).toLocaleDateString(
              "en-GB",
              dateFmt,
            );
            return (
              <li>
                <a href={`${base}/${post.slug}/`}>{post.title}</a>
                <span class="date">Updated {updated}</span>
              </li>
            );
          })
        }
      </ul>
    </div>
  </body>
</html>
