---
const GHOST_URL = import.meta.env.GHOST_URL;
const GHOST_API_KEY = import.meta.env.GHOST_API_KEY;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const assetVersion = "20260413";

const res = await fetch(
  `${GHOST_URL}/ghost/api/content/posts/?key=${GHOST_API_KEY}&include=tags&fields=slug,title,published_at,updated_at,custom_excerpt,feature_image,url&order=updated_at%20desc`,
);
const { posts: allPosts } = await res.json();
const ghostOrigin = allPosts[0]?.url
  ? new URL(allPosts[0].url).origin
  : GHOST_URL;
const rewriteUrl = (url: string | null) => {
  if (!url || !import.meta.env.PROD) return url;
  return url.replace(ghostOrigin, base);
};
const dateFmt = { day: "numeric", month: "long", year: "numeric" } as const;
const visible = allPosts
  .filter((p: any) => !p.tags?.some((t: any) => t.name === "#hidden"))
  .map((p: any) => ({
    slug: p.slug,
    title: p.title,
    custom_excerpt: p.custom_excerpt ?? null,
    feature_image: rewriteUrl(p.feature_image),
    tags: (p.tags ?? [])
      .filter((t: any) => !t.name.startsWith("#"))
      .map((t: any) => t.name),
    published_at: p.published_at,
    updatedLabel: `Updated ${new Date(p.updated_at).toLocaleDateString("en-GB", dateFmt)}`,
    publishedLabel: new Date(p.published_at).toLocaleDateString(
      "en-GB",
      dateFmt,
    ),
  }));

const cards = visible.filter(
  (p: any) => !p.tags.some((t: string) => t.toLowerCase() === "post"),
);
const blogPosts = visible
  .filter((p: any) => p.tags.some((t: string) => t.toLowerCase() === "post"))
  .sort(
    (a: any, b: any) =>
      new Date(b.published_at).getTime() - new Date(a.published_at).getTime(),
  );
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Projects & Blog — József Schaffer</title>
    <link rel="icon" href={`${base}/favicon.png?v=${assetVersion}`} />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600;12..96,700&family=Literata:ital,opsz,wght@0,7..72,400;0,7..72,500;0,7..72,600;1,7..72,400&display=swap"
    />
    <style is:global>
      @font-face {
        font-family: "Geist Pixel Square";
        src: url("/fonts/GeistPixel-Square.woff2") format("woff2");
        font-weight: 400;
        font-display: swap;
      }
      @font-face {
        font-family: "Geist Pixel Circle";
        src: url("/fonts/GeistPixel-Circle.woff2") format("woff2");
        font-weight: 400;
        font-display: swap;
      }
      @font-face {
        font-family: "Geist Pixel Grid";
        src: url("/fonts/GeistPixel-Grid.woff2") format("woff2");
        font-weight: 400;
        font-display: swap;
      }
      @font-face {
        font-family: "Geist Pixel Line";
        src: url("/fonts/GeistPixel-Line.woff2") format("woff2");
        font-weight: 400;
        font-display: swap;
      }
      @font-face {
        font-family: "Geist Pixel Triangle";
        src: url("/fonts/GeistPixel-Triangle.woff2") format("woff2");
        font-weight: 400;
        font-display: swap;
      }

      body {
        background-color: #e5e5e5;
        color: #2a1f23;
        font-family:
          "Bricolage Grotesque",
          system-ui,
          -apple-system,
          sans-serif;
        margin: 0;
      }

      .projects-shell {
        max-width: 1120px;
        margin: 0 auto;
        padding: 12rem 32px 10rem;
        position: relative;
        z-index: 2;
      }

      .projects-shell h1 {
        font-family: "Geist Pixel Line", system-ui, sans-serif;
        font-size: 5.4rem;
        font-weight: 400;
        letter-spacing: -0.02em;
        margin: 0 0 1.4rem;
        color: #aa00aa;
      }

      .projects-intro {
        font-family: "Literata", Georgia, serif;
        font-size: 1.9rem;
        line-height: 1.55;
        color: rgba(42, 31, 35, 0.65);
        margin: 0 0 6rem;
        max-width: 62ch;
      }

      .projects-grid {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 2.4rem;
      }

      .project-card {
        position: relative;
      }

      .project-card__link {
        display: flex;
        flex-direction: column;
        gap: 0;
        text-decoration: none;
        color: inherit;
        background: rgba(255, 255, 255, 0.55);
        border: 1px solid rgba(0, 0, 0, 0.12);
        border-radius: 18px;
        overflow: hidden;
        backdrop-filter: blur(12px) saturate(1.2);
        -webkit-backdrop-filter: blur(12px) saturate(1.2);
        box-shadow:
          0 1px 0 rgba(255, 255, 255, 0.7) inset,
          0 18px 40px -24px rgba(0, 0, 0, 0.22),
          0 4px 12px -6px rgba(0, 0, 0, 0.12);
        transition:
          transform 0.35s ease,
          box-shadow 0.35s ease,
          border-color 0.35s ease;
      }

      .project-card__link:hover {
        transform: translateY(-4px);
        border-color: rgba(0, 0, 0, 0.22);
        box-shadow:
          0 1px 0 rgba(255, 255, 255, 0.8) inset,
          0 26px 48px -24px rgba(0, 0, 0, 0.3),
          0 6px 18px -8px rgba(0, 0, 0, 0.16);
      }

      .project-card__canvas {
        position: relative;
        width: 100%;
        aspect-ratio: 5 / 3;
        overflow: hidden;
        background: linear-gradient(
          180deg,
          rgba(252, 220, 203, 0.55),
          rgba(252, 244, 238, 0) 80%
        );
      }

      .project-card__img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .project-card__content {
        padding: 2rem 2.2rem 2.4rem;
      }

      .project-card__title {
        font-family: "Geist Pixel Square", system-ui, sans-serif;
        font-size: 1.9rem;
        font-weight: 400;
        line-height: 1.25;
        letter-spacing: -0.01em;
        color: #2a0a2a;
        margin: 0 0 0.8rem;
      }

      .project-card__excerpt {
        font-family: "Literata", Georgia, serif;
        font-size: 1.35rem;
        line-height: 1.5;
        color: rgba(42, 31, 35, 0.62);
        margin: 0 0 1.4rem;
      }

      /* Tag pill token */
      :root {
        --tag-color: rgba(42, 31, 35, 0.42);
      }

      .project-card__tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 0.6rem;
      }

      .tag-pill {
        display: inline-block;
        font-family: "Bricolage Grotesque", system-ui, sans-serif;
        font-size: 0.85rem;
        font-weight: 500;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        padding: 0.25em 0.7em;
        border-radius: 999px;
        border: 1px solid var(--tag-color);
        color: var(--tag-color);
      }

      .project-card__date {
        font-family: "Bricolage Grotesque", system-ui, sans-serif;
        font-size: 0.92rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: rgba(42, 31, 35, 0.42);
      }

      /* Blog section */
      .blog-section {
        margin-top: 8rem;
      }

      .blog-section__title {
        font-family: "Geist Pixel Line", system-ui, sans-serif;
        font-size: 3.2rem;
        font-weight: 400;
        letter-spacing: -0.02em;
        color: #aa00aa;
        margin: 0 0 2.4rem;
      }

      .blog-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 2rem;
      }

      .blog-card__link {
        display: flex;
        gap: 0;
        text-decoration: none;
        color: inherit;
        background: rgba(255, 255, 255, 0.55);
        border: 1px solid rgba(0, 0, 0, 0.12);
        border-radius: 18px;
        overflow: hidden;
        backdrop-filter: blur(12px) saturate(1.2);
        -webkit-backdrop-filter: blur(12px) saturate(1.2);
        box-shadow:
          0 1px 0 rgba(255, 255, 255, 0.7) inset,
          0 18px 40px -24px rgba(0, 0, 0, 0.22),
          0 4px 12px -6px rgba(0, 0, 0, 0.12);
        transition:
          transform 0.35s ease,
          box-shadow 0.35s ease,
          border-color 0.35s ease;
      }

      .blog-card__link:hover {
        transform: translateY(-2px);
        border-color: rgba(0, 0, 0, 0.22);
        box-shadow:
          0 1px 0 rgba(255, 255, 255, 0.8) inset,
          0 26px 48px -24px rgba(0, 0, 0, 0.3),
          0 6px 18px -8px rgba(0, 0, 0, 0.16);
      }

      .blog-card__thumb {
        flex-shrink: 0;
        width: 220px;
        overflow: hidden;
      }

      .blog-card__thumb img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .blog-card__body {
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 1.8rem 2.2rem;
        min-width: 0;
      }

      .blog-card__title {
        font-family: "Geist Pixel Square", system-ui, sans-serif;
        font-size: 2rem;
        font-weight: 400;
        line-height: 1.25;
        letter-spacing: -0.01em;
        color: #2a0a2a;
        margin: 0 0 0.5rem;
      }

      .blog-card__excerpt {
        font-family: "Literata", Georgia, serif;
        font-size: 1.45rem;
        line-height: 1.5;
        color: rgba(42, 31, 35, 0.62);
        margin: 0 0 1rem;
      }

      .blog-card__date {
        font-family: "Bricolage Grotesque", system-ui, sans-serif;
        font-size: 0.92rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: rgba(42, 31, 35, 0.42);
      }

      @media (max-width: 600px) {
        .blog-card__link {
          flex-direction: column;
        }
        .blog-card__thumb {
          width: 100%;
          aspect-ratio: 5 / 3;
        }
      }

      .back-nav {
        position: fixed;
        top: 24px;
        left: 24px;
        z-index: 100;
        display: inline-flex;
        align-items: center;
        gap: 0.5em;
        padding: 0.6em 1.1em;
        background: rgba(0, 0, 0, 0.12);
        backdrop-filter: blur(12px) saturate(1.4);
        -webkit-backdrop-filter: blur(12px) saturate(1.4);
        border: 2px solid rgba(42, 31, 35, 0.8);
        border-radius: 999px;
        color: #2a1f23;
        font-family:
          "Bricolage Grotesque",
          system-ui,
          -apple-system,
          sans-serif;
        font-size: 2.1rem;
        font-weight: 500;
        text-decoration: none;
        transition:
          background 0.2s ease,
          color 0.2s ease,
          border-color 0.2s ease;
      }
      .back-nav:hover {
        background: #5c2a3e;
        color: #fcf4ee;
        border-color: #5c2a3e;
      }
      .back-nav-arrow {
        font-size: 1.1em;
        line-height: 1;
      }
      @media (max-width: 600px) {
        .back-nav {
          font-size: 1.47rem;
          top: 16px;
          left: 16px;
        }
        .projects-shell {
          padding: 10rem 20px 8rem;
        }
        .projects-shell h1 {
          font-size: 3.8rem;
        }
        .projects-intro {
          font-size: 1.6rem;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .project-card__link,
        .blog-card__link {
          transition: none;
        }
        .project-card__link:hover,
        .blog-card__link:hover {
          transform: none;
        }
      }
    </style>
  </head>
  <body>
    <a class="back-nav" href={`${base}/`}>
      <span class="back-nav-arrow">←</span>
      <span>jozsefschaffer.com</span>
    </a>
    <main class="projects-shell">
      <h1>Projects</h1>
      <p class="projects-intro">
        A mix of side projects, hobby builds, and various tech interests of
        mine. I hope you find some of these useful.
      </p>
      <ul class="projects-grid">
        {
          cards.map((post: any) => (
            <li class="project-card">
              <a class="project-card__link" href={`${base}/${post.slug}/`}>
                <div class="project-card__canvas">
                  {post.feature_image && (
                    <img
                      class="project-card__img"
                      src={post.feature_image}
                      alt=""
                      loading="lazy"
                    />
                  )}
                </div>
                <div class="project-card__content">
                  <h2 class="project-card__title">{post.title}</h2>
                  {post.tags.filter((t: string) => t.toLowerCase() !== "post")
                    .length > 0 && (
                    <div class="project-card__tags">
                      {post.tags
                        .filter((t: string) => t.toLowerCase() !== "post")
                        .map((tag: string) => (
                          <span
                            class="tag-pill"
                            data-tag={tag.toLowerCase().replace(/\s+/g, "-")}
                          >
                            {tag}
                          </span>
                        ))}
                    </div>
                  )}
                  {post.custom_excerpt && (
                    <p class="project-card__excerpt">{post.custom_excerpt}</p>
                  )}
                  <span class="project-card__date">{post.updatedLabel}</span>
                </div>
              </a>
            </li>
          ))
        }
      </ul>

      {
        blogPosts.length > 0 && (
          <section class="blog-section">
            <h2 class="blog-section__title">Blog</h2>
            <ul class="blog-list">
              {blogPosts.map((post: any) => (
                <li class="blog-card">
                  <a class="blog-card__link" href={`${base}/${post.slug}/`}>
                    {post.feature_image && (
                      <div class="blog-card__thumb">
                        <img src={post.feature_image} alt="" loading="lazy" />
                      </div>
                    )}
                    <div class="blog-card__body">
                      <h3 class="blog-card__title">{post.title}</h3>
                      {post.custom_excerpt && (
                        <p class="blog-card__excerpt">{post.custom_excerpt}</p>
                      )}
                      <span class="blog-card__date">{post.publishedLabel}</span>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )
      }
    </main>
  </body>
</html>
