---
import '../styles/ghost-content.css';
import '../styles/case-study.css';
import '../styles/post.css';
import '../styles/lightbox.css';
import '../styles/homepage/about-cursor.css';
import grafanaLogo from '../assets/grafana_logo.svg?raw';
import SiteFooter from '../components/SiteFooter.astro';

// Inline icons — use {{name}} tokens in Ghost prose to drop these into the text flow
const icons: Record<string, string> = {
  grafana: grafanaLogo,
};

export async function getStaticPaths() {
  const GHOST_URL = import.meta.env.GHOST_URL;
  const GHOST_API_KEY = import.meta.env.GHOST_API_KEY;

  const res = await fetch(
    `${GHOST_URL}/ghost/api/content/posts/?key=${GHOST_API_KEY}&include=tags,authors`
  );
  const { posts } = await res.json();

  return posts.map((post: any) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const GHOST_URL = import.meta.env.GHOST_URL;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const assetVersion = '20260413-2';
const { post } = Astro.props;
const isCaseStudy = post.tags?.some((t: any) => t.name === '#case-study');
const isBlogPost = post.tags?.some((t: any) => t.name.toLowerCase() === 'post');
const authorName = post.authors?.[0]?.name;
const dateFmt = { day: 'numeric', month: 'long', year: 'numeric' } as const;
const publishedDate = post.published_at
  ? new Date(post.published_at).toLocaleDateString('en-GB', dateFmt)
  : '';
const updatedDate = post.updated_at
  ? new Date(post.updated_at).toLocaleDateString('en-GB', dateFmt)
  : '';
const hasBeenUpdated = !isBlogPost && publishedDate && updatedDate && publishedDate !== updatedDate;

/**
 * Ghost alt-text conventions (signals stripped from output, never visible to users):
 *
 *   no-zoom      — disables lightbox on this image (adds data-no-lightbox)
 *   wide-width   — makes the image card span the wide grid column (adds kg-width-wide
 *                  to parent figure). Use this for animated GIFs/images where Ghost's
 *                  editor doesn't offer a width toggle.
 *
 * Ghost embed caption conventions (signals stripped from output):
 *
 *   wide-width   — makes the embed card span the wide grid column. Put it in the
 *                  embed card's caption field (Ghost doesn't expose alt for embeds).
 *                  If the caption only contains the signal, the figcaption is dropped.
 *
 * Ghost blockquote conventions (detected by content, styled via CSS):
 *
 *   "Fact sheet" as first line — styled as a bespoke fact-sheet card
 *
 * These conventions let us control rendering from Ghost's editor
 * without resorting to HTML cards or custom attributes Ghost doesn't support.
 */

// Process alt text conventions — strip signals, add data attributes
post.html = post.html.replace(
  /(<img\s[^>]*?)alt="([^"]*no-zoom[^"]*)"([^>]*>)/g,
  (match: string, before: string, alt: string, after: string) => {
    const cleanAlt = alt.replace(/\s*no-zoom\s*/g, '').trim();
    return `${before}alt="${cleanAlt}" data-no-lightbox${after}`;
  }
);

// wide-width signal — add kg-width-wide to the parent figure, strip from alt
post.html = post.html.replace(
  /<figure\s+class="([^"]*kg-image-card[^"]*)"([^>]*)>(\s*<img\s[^>]*?alt=")([^"]*wide-width[^"]*)("[^>]*>)/g,
  (_m: string, figClass: string, figRest: string, imgBefore: string, alt: string, imgAfter: string) => {
    const nextFigClass = figClass.includes('kg-width-wide') ? figClass : `${figClass} kg-width-wide`;
    const cleanAlt = alt.replace(/\s*wide-width\s*/g, '').trim();
    return `<figure class="${nextFigClass}"${figRest}>${imgBefore}${cleanAlt}${imgAfter}`;
  }
);

// wide-width signal in embed card caption — add kg-width-wide, strip signal,
// drop figcaption if it was the only content
post.html = post.html.replace(
  /<figure\s+class="([^"]*kg-embed-card[^"]*)"([^>]*)>([\s\S]*?)<figcaption[^>]*>([\s\S]*?)<\/figcaption>(\s*<\/figure>)/g,
  (match: string, figClass: string, figRest: string, figInner: string, captionInner: string, figEnd: string) => {
    if (!/wide-width/.test(captionInner)) return match;
    const nextFigClass = figClass.includes('kg-width-wide') ? figClass : `${figClass} kg-width-wide`;
    const cleanCaption = captionInner.replace(/\s*wide-width\s*/g, '').trim();
    const captionTextOnly = cleanCaption.replace(/<[^>]*>/g, '').trim();
    const captionHtml = captionTextOnly ? `<figcaption>${cleanCaption}</figcaption>` : '';
    return `<figure class="${nextFigClass}"${figRest}>${figInner}${captionHtml}${figEnd}`;
  }
);

// Replace Ghost's video player markup with a simple <video> tag
post.html = post.html.replace(
  /<figure class="kg-card kg-video-card([^"]*)"[^>]*data-kg-thumbnail="([^"]*)"[^>]*>[\s\S]*?<video src="([^"]*)"([^>]*)>[\s\S]*?(<figcaption[\s\S]*?<\/figcaption>)?\s*<\/figure>/g,
  (match: string, classes: string, thumbnail: string, src: string, videoAttrs: string, figcaption: string | undefined) => {
    const isLoop = videoAttrs.includes('loop');
    const attrs = isLoop
      ? 'loop autoplay muted playsinline preload="metadata"'
      : 'controls playsinline preload="metadata"';
    const width = (videoAttrs.match(/width="(\d+)"/) || [])[1] || '';
    const height = (videoAttrs.match(/height="(\d+)"/) || [])[1] || '';
    return `<figure class="kg-card kg-video-card${classes}">` +
      `<video src="${src}" poster="${thumbnail}" width="${width}" height="${height}" ${attrs}></video>` +
      (figcaption || '') +
      `</figure>`;
  }
);

// Tag "Fact sheet" blockquotes for custom styling, strip the label
post.html = post.html.replace(
  /<blockquote>\s*Fact sheet\s*(<br\s*\/?>)?\s*/gi,
  '<blockquote class="fact-sheet">'
);

// Convert "My contribution:" list inside fact sheet into a <ul>
post.html = post.html.replace(
  /(<blockquote class="fact-sheet">)([\s\S]*?)(<\/blockquote>)/g,
  (_m: string, open: string, inner: string, close: string) => {
    const parts = inner.split(/My contribution:\s*<br\s*\/?>/i);
    if (parts.length !== 2) return `${open}${inner}${close}`;
    const items = parts[1]
      .split(/<br\s*\/?>/i)
      .map((s: string) => s.trim())
      .filter(Boolean);
    const list = '<ul>' + items.map((i: string) => `<li>${i}</li>`).join('') + '</ul>';
    return `${open}${parts[0].replace(/(<br\s*\/?>\s*)+$/i, '')}<p class="fact-sheet__label">My contribution</p>${list}${close}`;
  }
);

// Replace {{name}} tokens with inline SVG icons
post.html = post.html.replace(/\{(\w+)\}/g, (match: string, name: string) => {
  const svg = icons[name];
  return svg ? `<span class="inline-icon">${svg}</span>` : match;
});

// Strip Ghost's ?ref= from outgoing links
post.html = post.html.replace(/\?ref=[^"&\s]*/g, '');

// Open all outgoing links in a new tab
post.html = post.html.replace(/<a\s+href="(https?:\/\/[^"]*)"([^>]*)>/g,
  (_m: string, href: string, rest: string) =>
    `<a href="${href}" target="_blank" rel="noopener noreferrer"${rest}>`
);

// Only rewrite Ghost URLs in production builds — in dev, Ghost serves them directly.
// Derive the origin from post.url so we catch whatever host Ghost is configured with
// (localhost, Tailscale, etc.), not just whatever GHOST_URL points at.
if (import.meta.env.PROD) {
  const ghostOrigin = post.url ? new URL(post.url).origin : GHOST_URL;
  post.html = post.html.replaceAll(ghostOrigin, base);
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{post.title} — József Schaffer</title>
    <meta name="description" content="Staff-level product designer working in complex digital ecosystems. I clarify direction, align teams, and get things done: I design, prototype, code, and stay accountable to outcomes, not decks." />
    <link rel="icon" href={`${base}/favicon.png?v=${assetVersion}`} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={post.title} />
    <meta property="og:image" content={`${base}/og-image.png?v=${assetVersion}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={post.title} />
    <meta name="twitter:image" content={`${base}/og-image.png?v=${assetVersion}`} />
    <style is:global>
      .case-study .gh-content {
        padding: 14rem 0;
      }
      .post .gh-content {
        padding: 8rem 0;
      }
    </style>
  </head>
  <body class={isCaseStudy ? 'case-study' : 'post'}>
    <nav class="post-nav" aria-label="Site navigation" data-about-cursor-root>
      <div class="post-nav__inner">
        <a
          class="post-nav__item"
          href={`${base}/projects/`}
          data-about-cursor-active
        >
          <span class="post-nav__copy">
            <span class="post-nav__label">Projects</span>
            <span class="post-nav__arrow" aria-hidden="true">←</span>
          </span>
        </a>
        <a
          class="post-nav__item post-nav__item--end"
          href={`${base}/`}
          data-about-cursor-active
        >
          <span class="post-nav__copy">
            <span class="post-nav__label">jozsefschaffer.com</span>
          </span>
        </a>
      </div>
    </nav>
    <article>
      <div class="gh-content">
        {!isCaseStudy && (
          <header class="post-header">
            <h1>{post.title}</h1>
            <div class="post-byline">
              {authorName && <span>{authorName}</span>}
              {authorName && publishedDate && <span> · </span>}
              {isBlogPost ? (
                publishedDate && <span>{publishedDate}</span>
              ) : (
                <>
                  {hasBeenUpdated && publishedDate && <span>Originally published {publishedDate}</span>}
                  {hasBeenUpdated && <span> · </span>}
                  {updatedDate && <span>{hasBeenUpdated ? `Updated ${updatedDate}` : publishedDate}</span>}
                </>
              )}
            </div>
          </header>
        )}
        <Fragment set:html={post.html} />
      </div>
    </article>
    <SiteFooter />
    <div class="about-cursor" data-about-cursor aria-hidden="true"></div>
    <script is:inline type="module" define:vars={{ base }}>
      import(`${base}/js/about-cursor.js`).then((m) => m.initAboutCursor());
    </script>
    <script is:inline>
      (() => {
        const nav = document.querySelector('.post-nav');
        if (!nav) return;
        const onScroll = () => {
          nav.classList.toggle('post-nav--compact', window.scrollY > 40);
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      })();
    </script>
    <script is:inline src={`${base}/js/ghost-cards.js`}></script>
    <script is:inline src={`${base}/js/lightbox.js`}></script>
  </body>
</html>
