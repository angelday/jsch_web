---
import "../../styles/landing.css";
import "../../styles/work.css";
import "../../styles/homepage/about-cursor.css";
import PageHeader from "../../components/PageHeader.astro";
import PcSound from "../../components/PcSound.astro";
import SiteFooter from "../../components/SiteFooter.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const assetVersion = "20260413-2";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#aaaaaa" />
    <title>Work — József Schaffer</title>
    <link rel="icon" href={`${base}/favicon.png?v=${assetVersion}`} />
  </head>
  <body data-about-cursor-root>
    <PageHeader base={base}>
      <canvas slot="backdrop" class="waveform waveform--hidden" data-waveform aria-hidden="true"></canvas>
      <button
        class="about-header__play"
        type="button"
        data-music-toggle
        data-music-src="/sounds/menu_music_1.mp3"
        data-about-cursor-active
        aria-label="Play music"
      >
        <span class="about-header__play-label">Play epic music</span>
      </button>
    </PageHeader>

    <ul class="work-grid">
      <li class="project-card">
        <div
          class="project-card__link project-card__link--static project-card__link--scene"
        >
          <div class="project-card__scene-copy" data-about-cursor-select>
            <h3 class="project-card__title">Inter IKEA Systems</h3>
            <div class="project-card__content project-card__content--scene">
              <p class="project-card__role">
                <strong>Product Designer (Kitchen Planner lead)</strong>
                <span>Jul 2022 - Present</span>
              </p>
              <p class="project-card__role">
                <strong
                  >Product Designer (KALLAX, PLATSA, SMÅSTAD 3D planners,
                  consultant)</strong
                >
                <span>Nov 2020 - Jul 2022</span>
              </p>
            </div>
          </div>
          <div class="project-card__canvas" data-ikea-canvas data-base={base}>
          </div>
        </div>
      </li>
      <li class="project-card">
        <div
          class="project-card__link project-card__link--static project-card__link--scene project-card__link--mapillary"
        >
          <div
            class="project-card__mapillary-canvas"
            data-mapillary-canvas
            data-base={base}
          >
          </div>
          <div class="project-card__scene-copy">
            <h3 class="project-card__title">
              <a
                class="project-card__title-link"
                href="https://www.mapillary.com/"
                target="_blank"
                rel="noopener noreferrer"
                data-about-cursor-active
              >
                Mapillary
              </a>
            </h3>
            <div
              class="project-card__content project-card__content--scene"
              data-about-cursor-select
            >
              <p class="project-card__role">
                <strong>Principal Designer</strong>
                <span>Sep 2018 - Jun 2020</span>
              </p>
              <p class="project-card__role">
                <strong>Lead Designer</strong>
                <span>Mar 2016 - Sep 2018</span>
              </p>
            </div>
          </div>
        </div>
      </li>
      <li class="work-logo-row">
        <ul class="work-logo-grid">
          <li class="project-card">
            <div class="project-card__link project-card__link--static work-logo-card">
              <a
                class="work-logo-card__logo-link work-logo-card__logo-link--prezi"
                href="https://prezi.com/"
                target="_blank"
                rel="noopener noreferrer"
                data-about-cursor-active
              >
                <img
                  class="work-logo-card__image"
                  src={`${base}/img/prezi-logo-cga.png`}
                  alt="Prezi"
                  loading="lazy"
                  decoding="async"
                  width="303"
                  height="114"
                />
              </a>
              <span class="work-logo-card__copy" data-about-cursor-select>
                <strong>Product Designer</strong>
                <span>2015 - 2016</span>
              </span>
            </div>
          </li>
          <li class="project-card">
            <div class="project-card__link project-card__link--static work-logo-card">
              <a
                class="work-logo-card__logo-link work-logo-card__logo-link--epam"
                href="https://www.epam.com/"
                target="_blank"
                rel="noopener noreferrer"
                data-about-cursor-active
              >
                <img
                  class="work-logo-card__image"
                  src={`${base}/img/epam-logo-cga.png`}
                  alt="EPAM"
                  loading="lazy"
                  decoding="async"
                  width="177"
                  height="66"
                />
              </a>
              <span class="work-logo-card__copy" data-about-cursor-select>
                <strong>Product Designer</strong>
                <span>2012 - 2015</span>
              </span>
            </div>
          </li>
        </ul>
      </li>
    </ul>

    <SiteFooter />
    <PcSound />
    <div class="about-cursor" data-about-cursor aria-hidden="true"></div>
    <script>
      import { initIkeaCardScene } from "../../scripts/ikea-card-scene.js";
      import { initMapillaryCardScene } from "../../scripts/mapillary-card-scene.js";

      initIkeaCardScene();
      initMapillaryCardScene();
    </script>
    <script>
      const btn = document.querySelector("[data-music-toggle]");
      if (btn) {
        const textLabel = btn.querySelector(".about-header__play-label");
        const header = document.querySelector("[data-compact-header]");
        const canvas = header.querySelector("[data-waveform]");
        const canvasCtx = canvas.getContext("2d");
        const PX = 2;

        let audio = null;
        let audioCtx = null;
        let analyser = null;
        let waveData = null;
        let rafId = null;
        let playing = false;

        const waveHide = "waveform--hidden";

        function sizeCanvas() {
          const rect = header.getBoundingClientRect();
          canvas.width = Math.floor(rect.width / PX);
          canvas.height = Math.floor(rect.height / PX);
        }

        function drawWaveform() {
          const W = canvas.width;
          const H = canvas.height;
          analyser.getByteTimeDomainData(waveData);
          canvasCtx.clearRect(0, 0, W, H);
          canvasCtx.fillStyle = "#aaaaaa";

          const mid = H / 2;
          const step = waveData.length / W;
          let prevY = Math.floor(mid + ((waveData[0] - 128) / 128) * mid);
          for (let x = 0; x < W; x++) {
            const index = Math.min(waveData.length - 1, Math.floor(x * step));
            const v = (waveData[index] - 128) / 128;
            const y = Math.floor(mid + v * mid);
            const top = Math.min(y, prevY);
            const bot = Math.max(y, prevY);
            canvasCtx.fillRect(x, top, 1, bot - top + 1);
            prevY = y;
          }
          rafId = requestAnimationFrame(drawWaveform);
        }

        function setPlaying(state) {
          playing = state;
          textLabel.textContent = state ? "Stop epic music" : "Play epic music";
          canvas.classList.toggle(waveHide, !state);
          btn.setAttribute("aria-label", state ? "Stop music" : "Play music");

          if (state) {
            sizeCanvas();
            rafId = requestAnimationFrame(drawWaveform);
          } else {
            cancelAnimationFrame(rafId);
            canvasCtx.clearRect(0, 0, canvas.width, canvas.height);
          }
        }

        window.addEventListener("resize", () => {
          if (playing) sizeCanvas();
        });

        btn.addEventListener("click", async () => {
          if (playing) {
            audio?.pause();
            audio.currentTime = 0;
            setPlaying(false);
          } else {
            if (!audio) {
              audio = new Audio(btn.dataset.musicSrc);
              const AudioContextClass = window.AudioContext || window.webkitAudioContext;
              audioCtx = new AudioContextClass();
              const source = audioCtx.createMediaElementSource(audio);
              analyser = audioCtx.createAnalyser();
              analyser.fftSize = 1024;
              waveData = new Uint8Array(analyser.fftSize);
              source.connect(analyser);
              source.connect(audioCtx.destination);
              audio.addEventListener("ended", () => setPlaying(false));
            }

            await audioCtx.resume();
            await audio.play();
            setPlaying(true);
          }
        });
      }
    </script>
    <script is:inline type="module" define:vars={{ base }}>
      import(`${base}/js/about-cursor.js`).then((m) => m.initAboutCursor());
    </script>
  </body>
</html>
