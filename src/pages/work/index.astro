---
import "../../styles/landing.css";
import "../../styles/work.css";
import "../../styles/homepage/about-cursor.css";
import PageHeader from "../../components/PageHeader.astro";
import PcSound from "../../components/PcSound.astro";
import SiteFooter from "../../components/SiteFooter.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const assetVersion = "20260413-2";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#aaaaaa" />
    <title>Work — József Schaffer</title>
    <link rel="icon" href={`${base}/favicon.png?v=${assetVersion}`} />
  </head>
  <body data-about-cursor-root>
    <PageHeader base={base}>
      <button
        class="about-header__play"
        type="button"
        data-music-toggle
        data-music-src="/sounds/menu_music_1.mp3"
        data-about-cursor-active
        aria-label="Play music"
      >
        <span class="about-header__play-label">Play</span>
        <svg class="about-header__play-icon" data-icon-play width="12" height="14" viewBox="0 0 12 14" fill="currentColor" aria-hidden="true">
          <path d="M0 0v14l12-7z" />
        </svg>
        <svg class="about-header__play-icon about-header__play-icon--hidden" data-icon-stop width="12" height="12" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true">
          <rect width="12" height="12" />
        </svg>
      </button>
    </PageHeader>

    <ul class="work-grid">
      <li class="project-card">
        <div
          class="project-card__link project-card__link--static project-card__link--scene"
        >
          <div class="project-card__scene-copy" data-about-cursor-select>
            <h3 class="project-card__title">Inter IKEA Systems</h3>
            <div class="project-card__content project-card__content--scene">
              <p class="project-card__role">
                <strong>Product Designer (Kitchen Planner lead)</strong>
                <span>Jul 2022 - Present</span>
              </p>
              <p class="project-card__role">
                <strong
                  >Product Designer (KALLAX, PLATSA, SMÅSTAD 3D planners,
                  consultant)</strong
                >
                <span>Nov 2020 - Jul 2022</span>
              </p>
            </div>
          </div>
          <div class="project-card__canvas" data-ikea-canvas data-base={base}>
          </div>
        </div>
      </li>
      <li class="project-card">
        <div
          class="project-card__link project-card__link--static project-card__link--scene project-card__link--mapillary"
        >
          <div
            class="project-card__mapillary-canvas"
            data-mapillary-canvas
            data-base={base}
          >
          </div>
          <div class="project-card__scene-copy">
            <h3 class="project-card__title">
              <a
                class="project-card__title-link"
                href="https://www.mapillary.com/"
                target="_blank"
                rel="noopener noreferrer"
                data-about-cursor-active
              >
                Mapillary
              </a>
            </h3>
            <div
              class="project-card__content project-card__content--scene"
              data-about-cursor-select
            >
              <p class="project-card__role">
                <strong>Principal Designer</strong>
                <span>Sep 2018 - Jun 2020</span>
              </p>
              <p class="project-card__role">
                <strong>Lead Designer</strong>
                <span>Mar 2016 - Sep 2018</span>
              </p>
            </div>
          </div>
        </div>
      </li>
      <li class="work-logo-row">
        <ul class="work-logo-grid">
          <li class="project-card">
            <div class="project-card__link project-card__link--static work-logo-card">
              <a
                class="work-logo-card__logo-link work-logo-card__logo-link--prezi"
                href="https://prezi.com/"
                target="_blank"
                rel="noopener noreferrer"
                data-about-cursor-active
              >
                <img
                  class="work-logo-card__image"
                  src={`${base}/img/prezi-logo-cga.png`}
                  alt="Prezi"
                  loading="lazy"
                  decoding="async"
                  width="303"
                  height="114"
                />
              </a>
              <span class="work-logo-card__copy" data-about-cursor-select>
                <strong>Product Designer</strong>
                <span>2015 - 2016</span>
              </span>
            </div>
          </li>
          <li class="project-card">
            <div class="project-card__link project-card__link--static work-logo-card">
              <a
                class="work-logo-card__logo-link work-logo-card__logo-link--epam"
                href="https://www.epam.com/"
                target="_blank"
                rel="noopener noreferrer"
                data-about-cursor-active
              >
                <img
                  class="work-logo-card__image"
                  src={`${base}/img/epam-logo-cga.png`}
                  alt="EPAM"
                  loading="lazy"
                  decoding="async"
                  width="177"
                  height="66"
                />
              </a>
              <span class="work-logo-card__copy" data-about-cursor-select>
                <strong>Product Designer</strong>
                <span>2012 - 2015</span>
              </span>
            </div>
          </li>
        </ul>
      </li>
    </ul>

    <SiteFooter />
    <PcSound />
    <div class="about-cursor" data-about-cursor aria-hidden="true"></div>
    <script>
      import { initIkeaCardScene } from "../../scripts/ikea-card-scene.js";
      import { initMapillaryCardScene } from "../../scripts/mapillary-card-scene.js";

      initIkeaCardScene();
      initMapillaryCardScene();
    </script>
    <script>
      const btn = document.querySelector("[data-music-toggle]");
      if (btn) {
        const label = btn.querySelector("[data-icon-play]")
          ? btn
          : null;
        const playIcon = btn.querySelector("[data-icon-play]");
        const stopIcon = btn.querySelector("[data-icon-stop]");
        const textLabel = btn.querySelector(".about-header__play-label");
        let audio = null;
        let playing = false;

        const hide = "about-header__play-icon--hidden";

        function setPlaying(state) {
          playing = state;
          textLabel.textContent = state ? "Stop" : "Play";
          playIcon.classList.toggle(hide, state);
          stopIcon.classList.toggle(hide, !state);
          btn.setAttribute("aria-label", state ? "Stop music" : "Play music");
        }

        btn.addEventListener("click", () => {
          if (playing) {
            audio?.pause();
            audio.currentTime = 0;
            setPlaying(false);
          } else {
            if (!audio) {
              audio = new Audio(btn.dataset.musicSrc);
              audio.addEventListener("ended", () => setPlaying(false));
            }
            audio.play();
            setPlaying(true);
          }
        });
      }
    </script>
    <script is:inline type="module" define:vars={{ base }}>
      import(`${base}/js/about-cursor.js`).then((m) => m.initAboutCursor());
    </script>
  </body>
</html>
