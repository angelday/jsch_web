---
import "../../styles/landing.css";
import "../../styles/work.css";
import "../../styles/homepage/about-cursor.css";
import SiteFooter from "../../components/SiteFooter.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const assetVersion = "20260413-2";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Work — József Schaffer</title>
    <link rel="icon" href={`${base}/favicon.png?v=${assetVersion}`} />
  </head>
  <body>
    <section
      class="mini-hero mini-hero--compact work-hero"
      data-about-cursor-root
    >
      <header class="mini-hero__nav" aria-label="Site navigation">
        <a
          class="mini-hero__nav-item"
          href={`${base}/`}
          data-about-cursor-active
        >
          <span class="mini-hero__nav-copy">
            <span class="mini-hero__nav-label">Home</span>
            <span class="mini-hero__nav-arrow" aria-hidden="true">←</span>
          </span>
        </a>
      </header>
    </section>

    <ul class="work-grid">
      <li class="project-card">
        <div
          class="project-card__link project-card__link--static project-card__link--scene"
        >
          <div class="project-card__scene-copy">
            <h3 class="project-card__title">Inter IKEA Systems</h3>
            <div class="project-card__content project-card__content--scene">
              <p class="project-card__role">
                <strong>Product Designer (Kitchen Planner lead)</strong>
                <span>Jul 2022 - Present</span>
              </p>
              <p class="project-card__role">
                <strong
                  >Product Designer (KALLAX, PLATSA, SMÅSTAD 3D planners,
                  consultant)</strong
                >
                <span>Nov 2020 - Jul 2022</span>
              </p>
            </div>
          </div>
          <div class="project-card__canvas" data-ikea-canvas data-base={base}>
          </div>
        </div>
      </li>
      <li class="project-card">
        <div
          class="project-card__link project-card__link--static project-card__link--scene project-card__link--mapillary"
        >
          <div
            class="project-card__mapillary-canvas"
            data-mapillary-canvas
            data-base={base}
          >
          </div>
          <div class="project-card__scene-copy">
            <h3 class="project-card__title">Mapillary</h3>
            <div class="project-card__content project-card__content--scene">
              <p class="project-card__role">
                <strong>Principal Designer</strong>
                <span>Sep 2018 - Jun 2020</span>
              </p>
              <p class="project-card__role">
                <strong>Lead Designer</strong>
                <span>Mar 2016 - Sep 2018</span>
              </p>
            </div>
          </div>
        </div>
      </li>
      <li class="work-logo-row">
        <ul class="work-logo-grid">
          <li class="project-card">
            <div class="project-card__link project-card__link--static work-logo-card">
              <span>Prezi</span>
            </div>
          </li>
          <li class="project-card">
            <div class="project-card__link project-card__link--static work-logo-card">
              <span>EPAM</span>
            </div>
          </li>
        </ul>
      </li>
    </ul>

    <SiteFooter />
    <div class="about-cursor" data-about-cursor aria-hidden="true"></div>
    <script>
      import { initIkeaCardScene } from "../../scripts/ikea-card-scene.js";
      import { initMapillaryCardScene } from "../../scripts/mapillary-card-scene.js";

      initIkeaCardScene();
      initMapillaryCardScene();
    </script>
    <script is:inline type="module" define:vars={{ base }}>
      import(`${base}/js/about-cursor.js`).then((m) => m.initAboutCursor());
    </script>
  </body>
</html>
