---
import "../styles/styles.css";
import Hero from "../components/Hero.astro";
import WorkSection from "../components/WorkSection.astro";
import AboutSection from "../components/AboutSection.astro";
import ProjectsSection from "../components/ProjectsSection.astro";
import ContactSection from "../components/ContactSection.astro";
import SiteFooter from "../components/SiteFooter.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const assetVersion = "20260413-2";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>József Schaffer — Product Designer</title>
    <meta
      name="description"
      content="Product designer on a CGA monitor by day. By night aspiring writer and pixel artist."
    />
    <link rel="icon" href={`${base}/favicon.png?v=${assetVersion}`} />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="József Schaffer — Product Designer" />
    <meta
      property="og:description"
      content="Product designer on a CGA monitor by day. By night aspiring writer and pixel artist."
    />
    <meta
      property="og:image"
      content={`${base}/og-image.png?v=${assetVersion}`}
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="József Schaffer — Product Designer" />
    <meta
      name="twitter:image"
      content={`${base}/og-image.png?v=${assetVersion}`}
    />
  </head>
  <body data-about-cursor-root>
    <main class="page-shell">
      <Hero base={base} />

      <AboutSection base={base} />
      <ProjectsSection base={base} />
      <WorkSection base={base} />
      <ContactSection base={base} />
    </main>
    <SiteFooter />

    <div class="about-cursor" data-about-cursor aria-hidden="true"></div>

    <script is:inline src={`${base}/js/main.js`} type="module"></script>
  </body>
</html>
