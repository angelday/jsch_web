---
import '../styles/styles.css';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>József Schaffer — Product Designer</title>
    <meta name="description" content="Staff-level product designer working in complex digital ecosystems. I clarify direction, align teams, and get things done: I design, prototype, code, and stay accountable to outcomes, not decks." />
    <link rel="icon" href={`${base}/favicon.png`} />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="József Schaffer — Product Designer" />
    <meta property="og:description" content="Staff-level product designer working in complex digital ecosystems. I clarify direction, align teams, and get things done." />
    <meta property="og:image" content={`${base}/og-image.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="József Schaffer — Product Designer" />
    <meta name="twitter:image" content={`${base}/og-image.png`} />
  </head>
  <body>
    <main class="page-shell">
      <section class="hero" aria-labelledby="hero-title">
        <canvas
          class="hero__shader"
          data-shader-canvas
          aria-hidden="true"
        ></canvas>

        <header class="hero__nav" aria-label="Hero navigation">
          <button
            class="hero__nav-item"
            type="button"
            data-scroll-target="#about-me"
            aria-controls="about-me"
          >
            <span class="hero__nav-copy">
              <span class="hero__nav-label">About me</span>
              <span class="hero__nav-arrow" aria-hidden="true">→</span>
            </span>
          </button>
          <button
            class="hero__nav-item"
            type="button"
            data-scroll-target="#case-study"
            aria-controls="case-study"
          >
            <span class="hero__nav-copy">
              <span class="hero__nav-label">Currently</span>
              <span class="hero__nav-arrow" aria-hidden="true">→</span>
            </span>
          </button>
          <button
            class="hero__nav-item"
            type="button"
            data-scroll-target="#contact"
            aria-controls="contact"
          >
            <span class="hero__nav-copy">
              <span class="hero__nav-label">Contact</span>
              <span class="hero__nav-arrow" aria-hidden="true">→</span>
            </span>
          </button>
        </header>

        <div class="hero__content">
          <div class="hero__title-group">
            <h1 id="hero-title">Jozsef Schaffer</h1>
          </div>
          <div class="hero__subtitle-group">
            <p class="hero__subtitle">Product designer</p>
          </div>
        </div>
      </section>

      <section
        class="section section--ikea"
        id="case-study"
        aria-label="IKEA case study preview"
      >
        <div class="section__touch-layer" aria-hidden="true"></div>
        <div class="section__brand">
          <img
            class="section__brand-logo"
            src={`${base}/IKEA_Logo_transparent.svg`}
            alt="IKEA"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="section__copy">
          <p class="section__copy-text">
            Currently at Inter IKEA working on 3D planning experiences.
          </p>
        </div>
        <div class="section__embed">
          <iframe
            class="section__iframe"
            src="https://angelday.github.io/jsch_static/visualization"
            title="IKEA visualization"
            loading="lazy"
          ></iframe>
        </div>
      </section>

      <section
        class="section section--about"
        id="about-me"
        data-about-cursor-root
        aria-label="About section"
      >
        <div class="section__about-content">
          <p class="section__about-title" data-about-cursor-select>About me</p>
          <div class="section__about-copy">
            <p class="section__about-text" data-about-cursor-select>
              I design and ship digital products.
            </p>
            <p class="section__about-text" data-about-cursor-select>
              For the past 15+ years, I've worked inside modern product teams, with a focus on delivery and impact.
            </p>
            <a
              class="section__about-link"
              href="#about-modal"
              aria-haspopup="dialog"
              aria-controls="about-modal"
              data-about-cursor-active
              data-theatre-open="#about-modal"
            >
              Learn more about me
            </a>
          </div>
        </div>
        <picture class="section__about-backdrop" aria-hidden="true">
          <source
            media="(max-width: 540px)"
            srcset={`${base}/about-cga-mobile.gif`}
          />
          <source
            media="(max-width: 900px)"
            srcset={`${base}/about-cga-tablet.gif`}
          />
          <img
            class="section__about-backdrop-image"
            src={`${base}/about-cga-desktop.gif`}
            alt=""
            loading="lazy"
            decoding="async"
          />
        </picture>
      </section>

      <section
        class="section section--contact"
        id="contact"
        aria-label="Contact section"
      >
        <div class="section__contact-grid">
          <a
            class="section__contact-card"
            href="https://www.linkedin.com/in/jozsefschaffer/"
            target="_blank"
            rel="noopener noreferrer"
          >
            <canvas
              class="section__contact-shader"
              data-shader-canvas
              data-shader-preset="contact-linkedin"
              data-shader-hover-preset="contact-linkedin-hover"
              aria-hidden="true"
            ></canvas>
            <span class="section__contact-card-label">
              Connect with me on LinkedIn
            </span>
          </a>
          <a
            class="section__contact-card"
            href="mailto:contact_at_this_domain"
          >
            <canvas
              class="section__contact-shader"
              data-shader-canvas
              data-shader-preset="contact-email"
              data-shader-hover-preset="contact-email-hover"
              aria-hidden="true"
            ></canvas>
            <span class="section__contact-card-label">Send an email</span>
          </a>
        </div>
      </section>

      <p class="page-byline">Last updated: Apr 2026</p>
    </main>

    <div
      class="theatre-modal"
      id="about-modal"
      data-theatre-modal
      data-theatre-theme="about"
      hidden
    >
      <div class="theatre-modal__backdrop" data-theatre-modal-close></div>
      <div class="theatre-modal__frame">
        <button
          class="theatre-modal__close"
          type="button"
          aria-label="Close about modal"
          data-theatre-modal-close
        >
          <picture class="theatre-modal__close-picture" aria-hidden="true">
            <source
              media="(max-width: 540px)"
              srcset={`${base}/close-mobile.svg`}
            />
            <img
              class="theatre-modal__close-icon"
              src={`${base}/close.svg`}
              alt=""
            />
          </picture>
        </button>
        <div
          class="theatre-modal__panel"
          role="dialog"
          aria-modal="true"
          aria-labelledby="about-modal-title"
          tabindex="-1"
        >
          <div class="theatre-modal__content">
            <div class="theatre-modal__media">
              <img
                class="theatre-modal__media-image"
                src={`${base}/whatever_it_takes.png`}
                alt=""
                aria-hidden="true"
              />
            </div>
            <header class="theatre-modal__header">
              <h2 class="theatre-modal__title" id="about-modal-title">
                Thanks for stopping by!
              </h2>
            </header>

            <section class="theatre-modal__section">
              <div class="theatre-modal__prose">
                <p class="theatre-modal__text">
                  I've been designing and building software professionally for 15+ years. Whether it's evolving what already exists or creating something entirely new, I love figuring out what to build.
                </p>
                <p class="theatre-modal__text">
                  Originally from Hungary, I'm a dad of three, happily married, and living in southern Sweden.
                </p>
                <p class="theatre-modal__text">
                  In my free time, I play Nintendo games, enjoy retro platformers, and do sports. I'm also passionate about pixel art.
                </p>
                <p class="theatre-modal__text">
                  My first name, József, is the Hungarian version of Joseph. In Hungarian, it's often shortened to Józsi. When pronounced in English, it often sounds like Yoshi. The nickname stuck, and that's what most people call me.
                </p>
              </div>
            </section>

            <section class="theatre-modal__section">
              <h3 class="theatre-modal__eyebrow">Design? How do I do it?</h3>
              <div class="theatre-modal__prose">
                <p class="theatre-modal__text">Not screens. Flows.</p>
                <p class="theatre-modal__text">
                  Start with a design concept for where we're headed, ideally a video showing the expected user journey. Then break it down into buildable chunks. Production is always the reference.
                </p>
              </div>
            </section>

            <section class="theatre-modal__section">
              <h3 class="theatre-modal__eyebrow">A quote I return to often</h3>
              <blockquote class="theatre-modal__quote">
                <p class="theatre-modal__text">
                  "Most of the things I am most proud of have come from just doing the thing<br />
                  Most people would rather ask questions, debate, etc<br />
                  Most decisions are two way doors and you are often times rewarded for taking the initiative"
                </p>
                <footer class="theatre-modal__quote-attribution">
                  — Logan Kilpatrick
                </footer>
              </blockquote>
            </section>

            <section class="theatre-modal__section">
              <h3 class="theatre-modal__eyebrow">Q&amp;A</h3>
              <dl class="theatre-modal__faq">
                <dt class="theatre-modal__question">
                  Did you create this website?
                </dt>
                <dd class="theatre-modal__answer">
                  Yes. I originally designed it in Framer, then rebuilt it in vanilla JavaScript.
                </dd>

                <dt class="theatre-modal__question">
                  What are these weird colors and fonts?
                </dt>
                <dd class="theatre-modal__answer">
                  A nod to late-'80s CGA graphics.
                </dd>

                <dt class="theatre-modal__question">What tools did you use?</dt>
                <dd class="theatre-modal__answer">
                  The usual web design stack: HTML, CSS, JavaScript. I also used Framer for the initial design and prototyping, and Figma for some of the graphics.
                </dd>

                <dt class="theatre-modal__question">
                  What video game system do you recommend buying?
                </dt>
                <dd class="theatre-modal__answer">
                  That would be the Nintendo Switch 2, thank you for asking.
                </dd>
              </dl>
            </section>

            <footer class="theatre-modal__footer">
              <p class="theatre-modal__signoff">
                You read it all the way through, yay!
              </p>
              <img
                class="theatre-modal__signoff-gif"
                src={`${base}/yoshi.gif`}
                alt="Yoshi"
              />
            </footer>
          </div>
        </div>
      </div>
    </div>

    <div class="about-cursor" data-about-cursor aria-hidden="true"></div>

    <script is:inline src={`${base}/js/main.js`} type="module"></script>
  </body>
</html>
