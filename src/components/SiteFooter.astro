---
import { formatCopyright } from "../lib/site-footer";
const siteFooter = formatCopyright();
---

<footer class="site-footer" data-about-cursor-select>{siteFooter}</footer>

<style is:global>
  .site-footer {
    margin: 0;
    padding: 32px 0;
    color: #000;
    font-family: "Geist Pixel Square", system-ui, sans-serif;
    font-size: 22px;
    font-weight: 400;
    line-height: 1.4;
    text-align: center;
  }

  @media (max-width: 900px) {
    .site-footer {
      font-size: 18px;
    }
  }

  @media (max-width: 540px) {
    .site-footer {
      padding: 12px 0;
      font-size: 16px;
    }
  }
</style>
