---
interface Props {
  base: string;
}
const { base } = Astro.props;
---

<section
  class="section section--about"
  id="about-me"
  aria-label="About section"
>
  <div class="section__about-content">
    <p class="section__about-title" data-about-cursor-select>About me</p>
    <div class="section__about-copy">
      <p class="section__about-text" data-about-cursor-select>
        I'm a software designer and systems thinker based in Malmö, Sweden,
        currently working at Inter IKEA.
      </p>
      <a
        class="section__about-link"
        href="#about-modal"
        aria-haspopup="dialog"
        aria-controls="about-modal"
        data-about-cursor-active
        data-theatre-open="#about-modal"
      >
        Learn more about me
      </a>
    </div>
  </div>
  <picture class="section__about-backdrop" aria-hidden="true">
    <source
      media="(max-width: 540px)"
      srcset={`${base}/img/about-cga-mobile.gif`}
    />
    <source
      media="(max-width: 900px)"
      srcset={`${base}/img/about-cga-tablet.gif`}
    />
    <img
      class="section__about-backdrop-image"
      src={`${base}/img/about-cga-desktop.gif`}
      alt=""
      loading="lazy"
      decoding="async"
    />
  </picture>
</section>
