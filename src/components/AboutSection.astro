---
interface Props {
  base: string;
}
const { base } = Astro.props;
---

<section
  class="section section--about"
  id="about-me"
  aria-label="About section"
>
  <div class="section__content">
    <div class="section__body">
      <p class="section__copy-text" data-about-cursor-select>
        I’m a software designer based in Malmö, Sweden, currently working at
        Inter IKEA.
      </p>
      <a
        class="section__link"
        href={`${base}/about/`}
        data-about-cursor-active
      >
        <span class="section__link-copy">
          <span class="section__link-label">More about me</span>
          <span class="section__link-arrow" aria-hidden="true">→</span>
        </span>
      </a>
    </div>
  </div>
</section>
