---
interface Props {
  base: string;
}
const { base } = Astro.props;
---

<section class="hero" aria-labelledby="hero-title">
  <canvas class="hero__shader" data-shader-canvas aria-hidden="true"></canvas>

  <header class="hero__nav" aria-label="Hero navigation">
    <a
      class="hero__nav-item"
      href="#about-modal"
      aria-haspopup="dialog"
      aria-controls="about-modal"
      data-about-cursor-active
      data-theatre-open="#about-modal"
    >
      <span class="hero__nav-copy">
        <span class="hero__nav-label">About me</span>
        <span class="hero__nav-arrow" aria-hidden="true">→</span>
      </span>
    </a>
    <button
      class="hero__nav-item"
      type="button"
      data-scroll-target="#work"
      aria-controls="work"
      data-about-cursor-active
    >
      <span class="hero__nav-copy">
        <span class="hero__nav-label">Work</span>
        <span class="hero__nav-arrow" aria-hidden="true">→</span>
      </span>
    </button>
    <a
      class="hero__nav-item"
      href={`${base}/projects/`}
      data-about-cursor-active
    >
      <span class="hero__nav-copy">
        <span class="hero__nav-label">Projects</span>
        <span class="hero__nav-arrow" aria-hidden="true">→</span>
      </span>
    </a>
    <button
      class="hero__nav-item"
      type="button"
      data-scroll-target="#contact"
      aria-controls="contact"
      data-about-cursor-active
    >
      <span class="hero__nav-copy">
        <span class="hero__nav-label">Contact</span>
        <span class="hero__nav-arrow" aria-hidden="true">→</span>
      </span>
    </button>
  </header>

  <div class="hero__content">
    <div class="hero__title-group">
      <h1 id="hero-title" data-about-cursor-select>József Schaffer</h1>
    </div>
    <div class="hero__subtitle-group">
      <p class="hero__subtitle" data-about-cursor-select>
        Product designer on a CGA monitor
      </p>
    </div>
  </div>
</section>
