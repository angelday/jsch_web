---
interface Props {
  base: string;
}
const { base } = Astro.props;
---

<section
  class="section section--work"
  id="work"
  aria-label="Work case study preview"
>
  <div class="section__touch-layer" aria-hidden="true"></div>
  <div class="section__brand">
    <img
      class="section__brand-logo"
      src={`${base}/img/IKEA_Logo_cga_pixelated.png`}
      alt="IKEA"
      loading="lazy"
      decoding="async"
    />
  </div>
  <div class="section__copy">
    <p class="section__copy-text" data-about-cursor-select>
      At work, I design 3D planning experiences.
    </p>
    <a class="section__link" href={`${base}/work/`} data-about-cursor-active>
      <span class="section__link-copy">
        <span class="section__link-label">Work history</span>
        <span class="section__link-arrow" aria-hidden="true">→</span>
      </span>
    </a>
  </div>
  <div class="section__embed">
    <canvas
      class="section__canvas"
      data-work-canvas
      data-viz-base={base}
      aria-hidden="true"></canvas>
  </div>
</section>

<script>
  const canvas = document.querySelector("[data-work-canvas]");
  let didLoad = false;

  async function loadWorkVisualization() {
    if (didLoad || !canvas) return;
    didLoad = true;
    const { initWorkVisualization } = await import(
      "../scripts/work-visualization.js"
    );
    initWorkVisualization();
  }

  if (canvas) {
    if ("IntersectionObserver" in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          if (entries.some((entry) => entry.isIntersecting)) {
            observer.disconnect();
            loadWorkVisualization();
          }
        },
        { rootMargin: "600px 0px" },
      );
      observer.observe(canvas);
    } else {
      loadWorkVisualization();
    }
  }
</script>
