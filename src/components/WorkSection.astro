---
interface Props {
  base: string;
}
const { base } = Astro.props;
---

<section
  class="section section--work"
  id="work"
  aria-label="Work case study preview"
>
  <div class="section__touch-layer" aria-hidden="true"></div>
  <div class="section__brand">
    <img
      class="section__brand-logo"
      src={`${base}/img/IKEA_Logo_cga_pixelated.png`}
      alt="IKEA"
      loading="lazy"
      decoding="async"
    />
  </div>
  <div class="section__copy">
    <p class="section__copy-text" data-about-cursor-select>
      At work I'm designing 3D planning experiences.
    </p>
    <button>More about my work (arrow)</button>
  </div>
  <div class="section__embed">
    <iframe
      class="section__iframe"
      src="https://angelday.github.io/jsch_static/visualization?v=20260412-2"
      title="Work visualization"
      loading="lazy"></iframe>
  </div>
</section>
