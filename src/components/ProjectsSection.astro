---
interface Props {
  base: string;
}
const { base } = Astro.props;
---

<section
  class="section section--projects"
  id="projects"
  aria-label="Projects section"
>
  <div class="section__content">
    <div class="section__body">
      <p class="section__copy-text" data-about-cursor-select>
        Outside of work, I like to tinker with code, design, and pixel art.
      </p>
      <a
        class="section__link"
        href={`${base}/projects/`}
        data-about-cursor-active
      >
        <span class="section__link-copy">
          <span class="section__link-label">My projects</span>
          <span class="section__link-arrow" aria-hidden="true">→</span>
        </span>
      </a>
    </div>
  </div>
  <picture class="section__backdrop" aria-hidden="true">
    <source
      media="(max-width: 540px)"
      srcset={`${base}/img/about-cga-mobile.gif`}
    />
    <source
      media="(max-width: 900px)"
      srcset={`${base}/img/about-cga-tablet.gif`}
    />
    <img
      class="section__backdrop-image"
      src={`${base}/img/about-cga-desktop.gif`}
      alt=""
      loading="lazy"
      decoding="async"
    />
  </picture>
</section>
